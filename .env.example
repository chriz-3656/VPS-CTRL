# VPS-CTRL Configuration Template
# Copy this file to .env and update the values

# The password required to log in to the dashboard
DASHBOARD_PASSWORD=admin

# A strong random secret for signing JWT tokens
# You can generate one with: openssl rand -base64 32
JWT_SECRET=change_me_to_something_very_long_and_random

# Set to 'production' for extra cookie security
NODE_ENV=development

# The port the server will listen on
PORT=5050
